          "x-go-name": "ID"
        },
        "source": {
          "description": "Source - The source of the occurrence which has happened.\n+required",
          "type": "string",
          "x-go-name": "Source"
        },
        "time": {
          "description": "Time - A Timestamp when the event happened.\n+required",
          "type": "string",
